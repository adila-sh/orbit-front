# URL base do backend. É também o Identity da adila.co (Better Auth) — o
# auth-client fala com ele sob `/api/auth/*`. Só variáveis com prefixo VITE_
# chegam ao bundle do cliente — trate-as como públicas.
VITE_API_URL=http://localhost:3000
# Adila Identity API (session, organizations and JWT minting)
VITE_AUTH_URL=https://identity.adila.co
